# SvelteKit server -> Rust backend (used by src/routes/api/v1/[...path])
BACKEND_URL=http://localhost:8080

# Browser -> backend WebSocket (live quotes). Client-exposed (PUBLIC_ prefix).
# Defaults to ws://<hostname>:8080/ws/quotes if unset.
PUBLIC_WS_URL=ws://localhost:8080/ws/quotes

# Rust backend (finviz-api)
BIND_ADDR=0.0.0.0:8080
CORS_ORIGIN=http://localhost:5173
# RUST_LOG=info,finviz_api=debug
